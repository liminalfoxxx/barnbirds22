

# This redirects the Escape key (and right-click) to your custom screen
define config.game_menu_action = ShowMenu("system_screen")

default system_subtab = "CONFIG" # Can be "CONFIG" or "HISTORY"





#    SCREENS
# в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҖвЈҖвЈҖвЈҖвЈҖв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв Җ
# в Җв Җв Җв Җв Җв Җв Җв Җв ҖвўҖвЈ вЈӨвЈӨвЈҖвЎҖв Җв Җв ҖвўҖвЈ вЈҙвЈҫвЎӣвЈӣв ҝвўӯвЎүвўүвЈ№вЈҝвЎӣв ¶вЈӨвЎҖв Җв Җв Җв Җв ҖвўҖвЈҖвЎҖв Җв Җв Җв Җв Җ
# в Җв Җв Җв Җв Җв Җв Җв Җв ҖвўёвЎҮв ҖвўҖв ҲвЎүв івўҰв ҫвЈҜвЈһвЈүв ҖвўҷвЈЎв ӨвЈ„вЈЁв ·вЈ„вЈҖвЈёв Ӣв ҷвЈ»вЈ·вЈӨвЈӨв ¶в ҹв ӣвў№вЈ§в Җв Җв Җв Җв Җ
# в Җв Җв Җв Җв Җв Җв Җв Җв Җв ҲвЈҝв җвўҺвў·вЎұвЎ„в Җв Җв Җв Җв үв ӣвў§вЈ„вЎӨв ¶вў§в ӨвЈ„вЈ©в Ҫв ҹв ӣв үв үв үвЈЎвЈ¶в Җв ҖвЈёвЎҮв Җв Җв Җв Җв Җ
# в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ёвЈҮв Ҳв үв үв Ҳв Җв Җв Җв Җв Җв Җв Җв ҲвўівЈ„вўҖвЎҙв Ӣв Ғв Җв Җв Җв Җв Җв Җв ӣв ҹв Ғвў вЎҝв Җв Җв Җв Җв Җв Җ
# в Җв Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈҝв Ҷв Җв Җв ҖвЈ вЎ–вЎ–в ¶вўӨвЎҖв Җв Җв Җв №в Ӣв Җв ҖвЈ в ’вЈҹв ӣв Івў„в Җв Җв ҖвЈ¶вЎҹв Ғв Җв Җв Җв Җв Җв Җ
# в Җв Җв Җв Җв Җв Җв Җв Җв Җв ҖвЈјвЎҸв Җв Җв ҖвЈјвЈҝвЈ§вЈҝв Җв Җвў№вЎ„в Җв Җв Җв Җв ҖвЈјвЈҝвЈ·вЈҝв Җв Җв Җвўів Җв Җв Ҳвў§в Җв Җв Җв Җв Җв Җв Җ
