


# TRACKS THE CURRENT ACTIVE LOG
default selected_journal = None

# A SIMPLE CLASS TO HOLD OUR STORY DATA
init python:
    class JournalEntry:
        def __init__(self, sender, subject, date, body):
            self.sender = sender
            self.subject = subject
            self.date = date
            self.body = body








